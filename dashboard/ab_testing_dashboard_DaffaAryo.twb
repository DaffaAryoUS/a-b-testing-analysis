      <aliases enabled='yes' />
      <column caption='CTR' datatype='real' default-format='p0.00%' name='[Calculation_1156150372597760]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(sum([click])/sum([impressions]))' />
      </column>
      <column caption='ATCR' datatype='real' default-format='p0.00%' name='[Calculation_1156150373621761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([add_to_cart])/sum([page_view])' />
      </column>
      <column caption='CR' datatype='real' default-format='p0.00%' name='[Calculation_1156150376579074]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([purchase])/COUNTD([user_id])' />
      </column>
      <column caption='Total User' datatype='integer' name='[Calculation_1156150377447427]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([user_id])' />
      </column>
      <column caption='Actual Revenue' datatype='integer' name='[Calculation_1156150441779204]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='if [purchase] = 1 then [revenue] ELSE 0 end' />
      </column>
      <column caption='funnel rate click' datatype='real' default-format='p0.00%' name='[Calculation_1798265590661131]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([click]) / COUNTD([user_id])' />
      </column>
      <column caption='funnel rate_add to cart ' datatype='real' default-format='p0.00%' name='[Calculation_1798265591599116]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([add_to_cart])/COUNTD([user_id])' />
      </column>
      <column caption='funnel rate_purchase' datatype='real' default-format='p0.00%' name='[Calculation_1798265592872974]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([purchase])/COUNTD([user_id])' />
      </column>
      <column caption='100%' datatype='integer' default-format='p0.00%' name='[Calculation_1798265593720847]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='min(1)' />
