          <datasource-dependencies datasource='federated.1otj3xb0fa7l9c11fu80c0x3kwlp'>
            <column caption='funnel rate click' datatype='real' default-format='p0.00%' name='[Calculation_1798265590661131]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([click]) / COUNTD([user_id])' />
            </column>
            <column caption='funnel rate_add to cart ' datatype='real' default-format='p0.00%' name='[Calculation_1798265591599116]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([add_to_cart])/COUNTD([user_id])' />
            </column>
            <column caption='funnel rate_purchase' datatype='real' default-format='p0.00%' name='[Calculation_1798265592872974]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='sum([purchase])/COUNTD([user_id])' />
            </column>
            <column caption='100%' datatype='integer' default-format='p0.00%' name='[Calculation_1798265593720847]' role='measure' type='quantitative'>
